  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Read the following text aloud after the first week of phase 4.\r\n\nBest
    Practice: \"I am so glad that we have created the impact structure! I remember
    that in our project \"Roast-Master\" (multi-function microwave) we constantly
    had difficulties with the interface between the control units. Switching between
    the modes \"baking\", \"heating\" and \"grilling\" simply didn't work. Through
    the effect structure it became clear that for the 3 original separate functionalities,
    we had 3 control units whose interfaces were not clearly described.\"\v\r"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
