      m_Calls: []
  m_text: 'Read the following text aloud after the first week has been covered in
    phase 1.


    Best Practice: "I remember we also created application scenarios
    in the Cook-Blade project (Thermomix development). In the process, we approached
    the colleagues in production to understand how the system should be produced.
    You can''t imagine how grateful the colleagues were to have the opportunity to
    share their concerns and requirements with us so early on."

'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
